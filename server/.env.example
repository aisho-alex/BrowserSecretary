# Knowledge Helper - Environment Configuration
# Copy this file to .env and fill in your values

# Server Configuration
HOST=127.0.0.1
PORT=8000
DEBUG=true

# Knowledge Base MCP Database Path
KB_DB_PATH=../knowledge_base_mcp/data/kb.db
KB_DATA_DIR=../knowledge_base_mcp/data

# LLM Configuration (OpenAI-compatible API)
# Supports: OpenAI, Together AI, Groq, OpenRouter, local LLMs, etc.
LLM_API_URL=https://api.openai.com/v1/chat/completions
LLM_API_KEY=sk-your-api-key-here
LLM_MODEL=gpt-4o-mini

# Alternative providers:
# Together AI: https://api.together.xyz/v1/chat/completions
# Groq: https://api.groq.com/openai/v1/chat/completions
# OpenRouter: https://openrouter.ai/api/v1/chat/completions
# Local Ollama: http://localhost:11434/v1/chat/completions

# CORS Origins (comma-separated for browser extension)
CORS_ORIGINS=chrome-extension://*,moz-extension://*

# Knowledge Graph Settings
GRAPH_MAX_NODES=100
GRAPH_MAX_EDGES=200
